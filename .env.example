# PDD Application Environment Configuration
# Copy this file to .env and adjust the values as needed

# Port mapping (host:container)
# The application will be accessible at http://your-server:PORT
PORT=8002

# Timezone for the container
TZ=UTC

# Example for different timezones:
# TZ=Europe/Madrid
# TZ=America/New_York
# TZ=Asia/Shanghai
# Secret key for JWT token signing — CHANGE THIS to a long random string in production
# Generate one with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production-use-a-long-random-string

# Allowed CORS origins (comma-separated, no trailing slash)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001